{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "curator",
  "identifier": "au.lsjc.curator",
  "build": { "frontendDist": "../src" },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Lockyc/curator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4Rjg2RTk0Q0JBNjNGOTUKUldTVlA2YkxsRzc0dUxFdnZjYnFrY0NKK0xmME5YU1RUUkJwWlYxbTcvYW5jWU8zVHlVVUViTXgK"
    }
  }
}
